$ P = (N k_B T)/V (1 + n gamma_1) quad quad n = N/V quad quad gamma_1 = 2 pi integral_0^infinity r^2 (1 - e^(-beta U(r))) dif r $

#pagebreak()

$ V_"disp" = V - N b quad quad P_"efectiva" = P + a N^2/V^2 $

#pagebreak()

$ (P + a N^2/V^2)(V - N b) = N k_B T $

#pagebreak()

$ kappa_T = -1/V (partial V)/(partial P)_T quad quad kappa_T > 0 thin "(estable)" quad quad kappa_T < 0 thin "(inestable)" $
